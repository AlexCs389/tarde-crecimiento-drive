{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "builder": "swc",
    "typeCheck": false
  },
  "generateOptions": {
    "spec": false
  },
  "watchOptions": {
    "ignored": [
      "dist/**",
      "node_modules/**"
    ]
  }
}
